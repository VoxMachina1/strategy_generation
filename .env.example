# Tiingo API keys for signal_pipeline
# Get a free key at https://www.tiingo.com/account/api
#
# Single key:
# TIINGO_API_KEYS=your_api_key_here
#
# Multiple keys (comma-separated, for rate-limit rotation):
# TIINGO_API_KEYS=key1,key2,key3
#
# Multiple keys (JSON array format, also accepted):
# TIINGO_API_KEYS=["key1","key2","key3"]
TIINGO_API_KEYS=your_api_key_here
